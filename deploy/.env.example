POSTGRES_USER=pulse
POSTGRES_PASSWORD=pulse
POSTGRES_DB=pulse

RABBITMQ_USER=pulse
RABBITMQ_PASSWORD=pulse
RABBITMQ_ERLANG_COOKIE=pulse_dev_cookie

MINIO_USER=pulse
MINIO_PASSWORD=pulse_secret
MINIO_ACCESS_KEY=pulse
MINIO_SECRET_KEY=pulse_secret
MINIO_PUBLIC_URL=http://localhost:9000

INTERNAL_API_SECRET=change_me_to_32_plus_random_bytes_before_any_deploy
SCRIPT_SECRET_KEK=change_me_to_32_plus_random_bytes_before_any_deploy
WEBHOOK_SECRET_KEK=change_me_to_32_plus_random_bytes_before_any_deploy
CA_ROOT_KEY_SECRET=change_me_to_32_plus_random_bytes_before_any_deploy

TURN_SECRET=change_me_to_32_plus_random_bytes_before_any_deploy
TURN_URLS=turn:localhost:3478

PULSE_API_URL=http://localhost:8080

# Application-level admin user in the pulse-rmm realm (created by keycloak-user-init)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# Keycloak (OIDC identity provider — owns auth, issues RSA-signed JWTs)
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_DB=keycloak
# Internal URL backends use to fetch JWKS (container network)
KEYCLOAK_URL=http://keycloak:8080
# Must match the iss claim on issued tokens (browser-facing host)
KEYCLOAK_ISSUER_URI=http://localhost:8180/realms/pulse-rmm
# Browser-facing URL for the webapp's keycloak-js adapter
VITE_KEYCLOAK_URL=http://localhost:8180
# Prod only (compose.prod.yaml): public auth hostname baked into Keycloak
KEYCLOAK_HOSTNAME=auth.pulse.example.com

SWAGGER_UI_ENABLED=true

# Spring profile(s). dev,loki for local; compose.prod.yaml flips this to prod,loki.
SPRING_PROFILES_ACTIVE=dev,loki

# mTLS between agent and api-gateway. On in dev so the cert flow is exercised.
PULSE_MTLS_ENABLED=true

GRAFANA_ADMIN_PASSWORD=admin
