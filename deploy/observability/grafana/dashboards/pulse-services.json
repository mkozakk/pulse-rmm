{
  "uid": "pulse-services",
  "title": "Pulse RMM — Service Overview",
  "tags": ["pulse-rmm"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "30s",
  "time": {"from": "now-1h", "to": "now"},
  "templating": {
    "list": [
      {
        "name": "service",
        "label": "Service",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "pulse-prometheus"},
        "query": {"query": "label_values(jvm_memory_used_bytes, service)", "refId": "PrometheusVariableQueryEditor-VariableQuery"},
        "refresh": 2,
        "includeAll": false,
        "multi": false,
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "id": 1, "title": "Up", "type": "stat",
      "gridPos": {"x": 0, "y": 0, "w": 4, "h": 4},
      "datasource": {"type": "prometheus", "uid": "pulse-prometheus"},
      "targets": [{"refId": "A", "expr": "up{job=\"pulse-services\", service=\"$service\"}"}],
      "options": {"colorMode": "background", "graphMode": "none", "textMode": "value"},
      "fieldConfig": {"defaults": {"mappings": [{"type": "value", "options": {"0": {"text": "DOWN", "color": "red"}, "1": {"text": "UP", "color": "green"}}}]}}
    },
    {
      "id": 2, "title": "JVM heap used (%)", "type": "timeseries",
      "gridPos": {"x": 4, "y": 0, "w": 10, "h": 8},
      "datasource": {"type": "prometheus", "uid": "pulse-prometheus"},
      "targets": [{"refId": "A", "expr": "sum(jvm_memory_used_bytes{service=\"$service\", area=\"heap\"}) / sum(jvm_memory_max_bytes{service=\"$service\", area=\"heap\"}) * 100"}],
      "fieldConfig": {"defaults": {"unit": "percent", "min": 0, "max": 100}}
    },
    {
      "id": 3, "title": "HTTP request rate (req/s)", "type": "timeseries",
      "gridPos": {"x": 14, "y": 0, "w": 10, "h": 8},
      "datasource": {"type": "prometheus", "uid": "pulse-prometheus"},
      "targets": [{"refId": "A", "expr": "sum by (status) (rate(http_server_requests_seconds_count{service=\"$service\"}[1m]))", "legendFormat": "{{status}}"}]
    },
    {
      "id": 4, "title": "HTTP mean latency (s)", "type": "timeseries",
      "gridPos": {"x": 0, "y": 8, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "pulse-prometheus"},
      "targets": [{"refId": "A", "expr": "sum by (uri) (rate(http_server_requests_seconds_sum{service=\"$service\"}[1m])) / sum by (uri) (rate(http_server_requests_seconds_count{service=\"$service\"}[1m]))", "legendFormat": "{{uri}}"}],
      "fieldConfig": {"defaults": {"unit": "s"}}
    },
    {
      "id": 5, "title": "DB connections", "type": "timeseries",
      "gridPos": {"x": 12, "y": 8, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "pulse-prometheus"},
      "targets": [
        {"refId": "A", "expr": "hikaricp_connections_active{service=\"$service\"}", "legendFormat": "active"},
        {"refId": "B", "expr": "hikaricp_connections_idle{service=\"$service\"}", "legendFormat": "idle"},
        {"refId": "C", "expr": "hikaricp_connections_pending{service=\"$service\"}", "legendFormat": "pending"}
      ]
    },
    {
      "id": 6, "title": "GC pause time (s/s)", "type": "timeseries",
      "gridPos": {"x": 0, "y": 16, "w": 12, "h": 6},
      "datasource": {"type": "prometheus", "uid": "pulse-prometheus"},
      "targets": [{"refId": "A", "expr": "sum by (cause) (rate(jvm_gc_pause_seconds_sum{service=\"$service\"}[1m]))", "legendFormat": "{{cause}}"}],
      "fieldConfig": {"defaults": {"unit": "s"}}
    },
    {
      "id": 7, "title": "Log events rate", "type": "timeseries",
      "gridPos": {"x": 12, "y": 16, "w": 12, "h": 6},
      "datasource": {"type": "prometheus", "uid": "pulse-prometheus"},
      "targets": [{"refId": "A", "expr": "sum by (level) (rate(logback_events_total{service=\"$service\"}[1m]))", "legendFormat": "{{level}}"}]
    },
    {
      "id": 8, "title": "Logs", "type": "logs",
      "gridPos": {"x": 0, "y": 22, "w": 24, "h": 10},
      "datasource": {"type": "loki", "uid": "pulse-loki"},
      "targets": [{"refId": "A", "expr": "{service=\"$service\"}"}],
      "options": {"showTime": true, "wrapLogMessage": true, "enableLogDetails": true}
    }
  ]
}
