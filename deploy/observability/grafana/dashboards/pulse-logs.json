{
  "uid": "pulse-logs",
  "title": "Pulse RMM — Logs",
  "tags": ["pulse-rmm"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "10s",
  "time": {"from": "now-1h", "to": "now"},
  "templating": {
    "list": [
      {
        "name": "service",
        "label": "Service",
        "type": "query",
        "datasource": {"type": "loki", "uid": "pulse-loki"},
        "query": "label_values(service)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "sort": 1
      },
      {
        "name": "level",
        "label": "Level",
        "type": "custom",
        "query": "INFO,WARN,ERROR,DEBUG,TRACE",
        "includeAll": true,
        "multi": true,
        "current": {"text": "All", "value": "$__all"}
      }
    ]
  },
  "panels": [
    {
      "id": 1, "title": "Log volume by level (per service)", "type": "timeseries",
      "gridPos": {"x": 0, "y": 0, "w": 24, "h": 6},
      "datasource": {"type": "loki", "uid": "pulse-loki"},
      "targets": [{"refId": "A", "expr": "sum by (service, level) (rate({service=~\"$service\", level=~\"$level\"}[1m]))", "legendFormat": "{{service}} {{level}}"}]
    },
    {
      "id": 2, "title": "Logs", "type": "logs",
      "gridPos": {"x": 0, "y": 6, "w": 24, "h": 22},
      "datasource": {"type": "loki", "uid": "pulse-loki"},
      "targets": [{"refId": "A", "expr": "{service=~\"$service\", level=~\"$level\"}"}],
      "options": {"showTime": true, "wrapLogMessage": true, "enableLogDetails": true, "dedupStrategy": "none", "sortOrder": "Descending"}
    }
  ]
}
