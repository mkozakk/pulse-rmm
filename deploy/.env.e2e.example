POSTGRES_USER=pulse_e2e
POSTGRES_PASSWORD=pulse_e2e
POSTGRES_DB=pulse_e2e

RABBITMQ_USER=pulse_e2e
RABBITMQ_PASSWORD=pulse_e2e
RABBITMQ_ERLANG_COOKIE=pulse_e2e_cookie

MINIO_USER=pulse_e2e
MINIO_PASSWORD=pulse_e2e_secret
MINIO_ACCESS_KEY=pulse_e2e
MINIO_SECRET_KEY=pulse_e2e_secret

INTERNAL_API_SECRET=e2e_internal_secret_32_bytes_ok!

PULSE_API_URL=http://localhost:8081
PULSE_GRPC_ADDR=127.0.0.1:9091

# Keycloak (e2e stack runs on port 8181 so dev stack on 8180 can run simultaneously)
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
# Internal URL used by Spring services inside containers to fetch JWKS
KEYCLOAK_URL=http://keycloak:8080
# Must match the iss claim on issued tokens (host-facing port)
KEYCLOAK_ISSUER_URI=http://localhost:8181/realms/pulse-rmm
# Pytest runs on the host — cannot reach the container-internal KEYCLOAK_URL
KEYCLOAK_TEST_URL=http://localhost:8181

SCRIPT_SECRET_KEK=e2e_script_secret_kek_32_bytes_ok!
WEBHOOK_SECRET_KEK=e2e_webhook_secret_kek_32_bytes!!
CA_ROOT_KEY_SECRET=e2e_ca_root_secret_32_bytes_ok!!

TURN_SECRET=e2e_turn_secret_for_local_testing
TURN_URLS=turn:localhost:3479
PULSE_TURN_PORT=3479

SWAGGER_UI_ENABLED=true
